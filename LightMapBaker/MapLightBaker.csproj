<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>maplightbaker</AssemblyName>
    <RootNamespace>MapLightBaker</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Single dependency: a small, pure-managed PNG/image encoder.
         No native libs, works anywhere dotnet runs. -->
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.11" />
  </ItemGroup>

</Project>
